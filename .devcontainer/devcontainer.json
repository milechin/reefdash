{
  "name": "ReefDash",
  "build": {
    "context": "..",
    "dockerfile": "../Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "forwardPorts": [80],
  "portsAttributes": {
    "80": {
      "label": "ReefDash",
      "onAutoForward": "openBrowser"
    }
  }
}
